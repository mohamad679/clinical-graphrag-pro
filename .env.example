# Clinical GraphRAG Pro — environment template
# Copy this file to `.env` (or `backend/.env` for Docker) and replace placeholder values.

# APP_NAME: Human-readable application name shown in logs and health endpoints. Optional.
APP_NAME="Clinical GraphRAG Pro"
# APP_VERSION: Semantic version string exposed by the API. Optional.
APP_VERSION="1.0.0"
# APP_ENV: Deployment environment. Required for secure configuration checks. Allowed: development | staging | production.
APP_ENV=development
# DEBUG: Enables verbose logging and relaxed local behavior. Required.
DEBUG=false
# OBSERVABILITY_MODE: LOCAL_SYNTHETIC_DEBUG | STAGING_REDACTED | PRODUCTION_METADATA_ONLY.
# Production startup requires PRODUCTION_METADATA_ONLY.
OBSERVABILITY_MODE=LOCAL_SYNTHETIC_DEBUG

# API_PREFIX: Prefix applied to API routes. Optional.
API_PREFIX=/api
# CORS_ORIGINS: Comma-separated frontend origins allowed to call the API. Required for browser use.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ALLOW_CREDENTIALS: Whether credentialed CORS requests are allowed. Optional.
CORS_ALLOW_CREDENTIALS=true
# CORS_ALLOW_METHODS: Comma-separated allowed HTTP methods. Optional.
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOW_HEADERS: Comma-separated allowed HTTP headers. Optional.
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin

# DATABASE_URL: Async SQLAlchemy connection string. Required.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/clinical_graphrag
# AUTO_MIGRATE_ON_STARTUP: Apply pending Alembic migrations before serving requests. Recommended for demo/Space deployments.
AUTO_MIGRATE_ON_STARTUP=true
# POSTGRES_USER: Docker Compose PostgreSQL username. Required for local Docker deployments.
POSTGRES_USER=postgres
# POSTGRES_PASSWORD: Docker Compose PostgreSQL password. Required for local Docker deployments.
POSTGRES_PASSWORD=postgres
# POSTGRES_DB: Docker Compose PostgreSQL database name. Required for local Docker deployments.
POSTGRES_DB=clinical_graphrag

# REDIS_URL: Redis connection string used for caching and Celery. Required for workers/caching.
REDIS_URL=redis://redis:6379/0
# CACHE_ENABLED / CACHE_BACKEND: choose in-memory for local demo, redis for distributed cache.
CACHE_ENABLED=true
CACHE_BACKEND=redis
# WS_TICKET_TTL_SECONDS: Short-lived single-use WebSocket ticket TTL. Must be 30-60 seconds.
WS_TICKET_TTL_SECONDS=45
# CACHE_TTL: Cache lifetime in seconds. Optional.
CACHE_TTL=3600
# CELERY_TASK_ALWAYS_EAGER: Run tasks inline instead of through Redis/Celery. Optional, mainly for tests.
CELERY_TASK_ALWAYS_EAGER=false
# CELERY_TASK_STORE_EAGER_RESULT: Preserve eager task results. Optional.
CELERY_TASK_STORE_EAGER_RESULT=false

# GROQ_API_KEY: Groq API key for LLM inference. Optional if using Gemini instead.
GROQ_API_KEY=
# GROQ_MODEL: Groq model name. Optional.
GROQ_MODEL=llama-3.3-70b-versatile
# GOOGLE_API_KEY: Google Gemini API key. Optional if using Groq instead.
GOOGLE_API_KEY=
# GEMINI_MODEL: Gemini model name. Optional.
GEMINI_MODEL=gemini-2.5-flash-lite
# LLM_PROVIDER: Active provider used by the app. Required if you configure multiple providers. Allowed: groq | gemini.
LLM_PROVIDER=gemini
# LLM_MODEL: Display name of the active model. Optional.
LLM_MODEL=gemini-2.5-flash-lite

# CHUNK_SIZE: Approximate words per chunk for document indexing. Optional.
CHUNK_SIZE=512
# CHUNK_OVERLAP: Overlap between adjacent chunks. Optional.
CHUNK_OVERLAP=64
# TOP_K: Default number of retrieved chunks. Optional.
TOP_K=5
# EMBEDDING_MODEL: Sentence-transformers model name for embeddings. Required for retrieval.
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
# EMBEDDING_DIM: Embedding vector dimension. Required and must match the embedding model.
EMBEDDING_DIM=768
# VECTOR_BACKEND: Vector store implementation. Allowed: faiss | qdrant. Optional.
VECTOR_BACKEND=faiss
# QDRANT_URL: Base URL for Qdrant when VECTOR_BACKEND=qdrant. Required only for Qdrant deployments.
QDRANT_URL=
# QDRANT_API_KEY: API key for managed Qdrant. Optional.
QDRANT_API_KEY=
# QDRANT_COLLECTION: Qdrant collection name. Optional.
QDRANT_COLLECTION=clinical_graphrag
# RERANKER_MODEL: Cross-encoder reranker model name. Optional.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# USE_RERANKING: Enable reranking in retrieval. Optional.
USE_RERANKING=false
# USE_QUERY_EXPANSION: Enable LLM-based query expansion. Optional.
USE_QUERY_EXPANSION=true
# USE_HYBRID_SEARCH: Combine dense and BM25 retrieval. Optional.
USE_HYBRID_SEARCH=true

# ENABLE_FINE_TUNE: Enables fine-tuning endpoints. Optional and false by default in production.
ENABLE_FINE_TUNE=false
# FINE_TUNE_BASE_MODEL: Base model used for LoRA fine-tuning jobs. Optional.
FINE_TUNE_BASE_MODEL=unsloth/Meta-Llama-3.1-8B-bnb-4bit
# LORA_RANK: LoRA rank parameter. Optional.
LORA_RANK=16
# LORA_ALPHA: LoRA alpha parameter. Optional.
LORA_ALPHA=32
# LEARNING_RATE: Fine-tuning learning rate. Optional.
LEARNING_RATE=2e-4
# NUM_EPOCHS: Fine-tuning epoch count. Optional.
NUM_EPOCHS=3
# MAX_SEQ_LENGTH: Fine-tuning max sequence length. Optional.
MAX_SEQ_LENGTH=2048
# ADAPTERS_DIR: Directory for adapter checkpoints. Optional.
ADAPTERS_DIR=./data/adapters
# SCISPACY_MODEL: SciSpaCy model package name. Optional.
SCISPACY_MODEL=en_core_sci_sm
# ENABLE_SCISPACY: Enable SciSpaCy entity normalization. Optional.
ENABLE_SCISPACY=false

# JWT_SECRET: Secret used to sign JWTs. Required in non-debug deployments and must be at least 32 characters.
JWT_SECRET=replace-with-a-secure-random-secret-at-least-32-characters
# SECRET_KEY_MIN_LENGTH: Minimum accepted JWT secret length. Optional.
SECRET_KEY_MIN_LENGTH=32
# JWT_EXPIRE_MINUTES: Access token expiry in minutes. Optional.
JWT_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS: Refresh token/session expiry in days. Optional.
REFRESH_TOKEN_EXPIRE_DAYS=30
# PASSWORD_RESET_TOKEN_EXPIRE_MINUTES: Password reset token expiry in minutes. Optional.
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
# ENABLE_DEMO_AUTH: Legacy compatibility flag. Runtime auth is DB-backed and no longer seeds demo users.
ENABLE_DEMO_AUTH=false
# BOOTSTRAP_ADMIN_EMAIL: Optional input for the one-time bootstrap command.
BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD: Optional input for the one-time bootstrap command.
BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_NAME: Optional display name for the one-time bootstrap command.
BOOTSTRAP_ADMIN_NAME=Administrator
# RATE_LIMIT_ENABLED: Enable API rate limiting middleware. Optional.
RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE: Requests per minute per client. Optional.
RATE_LIMIT_PER_MINUTE=60

# UPLOAD_DIR: Directory for uploaded files. Optional.
UPLOAD_DIR=./uploads
# MAX_UPLOAD_SIZE_MB: Maximum uploaded file size. Optional.
MAX_UPLOAD_SIZE_MB=50

# USE_NEO4J: Enable Neo4j-backed graph queries instead of local temporal graph. Optional.
USE_NEO4J=false
# NEO4J_URI: Neo4j Bolt URI. Required only when USE_NEO4J=true.
NEO4J_URI=bolt://neo4j:7687
# NEO4J_USER: Neo4j username. Required only when USE_NEO4J=true.
NEO4J_USER=neo4j
# NEO4J_PASSWORD: Neo4j password. Required only when USE_NEO4J=true.
NEO4J_PASSWORD=change-this-password

# WS_HEARTBEAT_INTERVAL: WebSocket heartbeat interval in seconds. Optional.
WS_HEARTBEAT_INTERVAL=30
# DATA_RETENTION_DAYS: Nightly purge threshold for old chat sessions. Optional.
DATA_RETENTION_DAYS=365
# DISCLAIMER_TEXT: Clinical safety disclaimer shown in the UI and API. Optional.
DISCLAIMER_TEXT="This project is for educational and portfolio demonstration purposes only. It is not a medical device, not clinically validated, and must not be used for diagnosis, treatment, triage, medication decisions, or real patient care. All outputs require review by qualified clinical professionals."
