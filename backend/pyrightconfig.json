{
  "include": [
    "app/services/llm.py",
    "app/services/query_engine.py",
    "app/services/cost_estimator.py",
    "app/core/auth.py",
    "app/core/caching.py",
    "app/core/metrics.py",
    "app/core/redis.py"
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    ".venv"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "reportMissingImports": "warning",
  "reportMissingTypeStubs": false,
  "pythonVersion": "3.11",
  "typeCheckingMode": "basic"
}
