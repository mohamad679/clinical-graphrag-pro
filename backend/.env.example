# Backend environment variables
# Copy this to backend/.env for local development only. Do not commit real secrets.

# ── App ──────────────────────────────────────────────────
APP_NAME="Clinical GraphRAG Pro"
DEBUG=false
APP_ENV=development
OBSERVABILITY_MODE=LOCAL_SYNTHETIC_DEBUG

# ── LLM Providers (at least one required) ────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/clinical_graphrag
AUTO_MIGRATE_ON_STARTUP=true

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_BACKEND=in-memory
CACHE_TTL=3600
WS_TICKET_TTL_SECONDS=45

# ── RAG Settings ─────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_DIM=768
# Set to true to use deterministic hash embeddings for 
# offline CI/testing without downloading models
OFFLINE_DEMO_MODE=false

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=replace-with-a-secure-random-secret-at-least-32-characters
JWT_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Administrator

# ── File Storage ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ── WebSocket ────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30

# Medical disclaimer displayed by API/UI surfaces.
DISCLAIMER_TEXT="This project is for educational and portfolio demonstration purposes only. It is not a medical device, not clinically validated, and must not be used for diagnosis, treatment, triage, medication decisions, or real patient care. All outputs require review by qualified clinical professionals."
